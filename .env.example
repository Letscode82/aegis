# Copy to .env.local and edit. .env.local is gitignored.
#
# Local dev (after `docker compose up -d`):
DATABASE_URL="postgresql://aegis:aegis@localhost:5432/aegis?schema=public"

# Server-only — never expose to the client. /api/claude proxies through this.
ANTHROPIC_API_KEY=

# Intake agents production gate. All six agents are now real (Claude-backed)
# and productionReady, so this flag currently hides nothing. It remains the
# seam for any FUTURE not-yet-real agent: mark it productionReady:false and
# it stays hidden unless this is "true". NEXT_PUBLIC_ so it reaches the
# client bundle at build time.
NEXT_PUBLIC_AEGIS_DEMO_AGENTS=false
